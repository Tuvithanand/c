7.	Write a C program to demonstrate the use of constant values (const) in C.
#include <stdio.h>
int main() {
    const float PI = 3.14159;
    const int DAYS_IN_WEEK = 7;
    float radius = 5.0;
    float area = PI * radius * radius;
    printf("--- Constant Demonstration ---\n");
    printf("The value of PI is: %.5f\n", PI);
    printf("Days in a week: %d\n", DAYS_IN_WEEK);
    printf("Area of a circle with radius %.1f is: %.2f\n\n", radius, area);
    printf("Note: If you try to reassign a 'const' variable, \n");
    printf("the compiler will throw an error.\n");
    return 0;
}

8.	Write a C program to find the square and cube of a number.
#include <stdio.h>
int main() {
    float num, square, cube;
    printf("Enter a number: ");
    scanf("%f", &num);
    square = num * num;
    cube = num * num * num;
    printf("Square of %.2f is: %.2f\n", num, square);
    printf("Cube of %.2f is: %.2f\n", num, cube);
    return 0;
}

9.	Write a C program to convert seconds into hours, minutes, and seconds.
#include <stdio.h>
int main() {
    int total_seconds, hours, minutes, seconds;
    printf("Enter total seconds: ");
    scanf("%d", &total_seconds);
    hours = total_seconds / 3600;
    minutes = (total_seconds % 3600) / 60;
    printf("%d seconds is equivalent to: %d hours, %d minutes, and %d seconds\n", 
            total_seconds, hours, minutes, seconds);
    return 0;
}





