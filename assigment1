1.	Write a C program to find the sum, difference, product, and division of two numbers
#include <stdio.h>
int main() {
    float num1, num2;
    float sum, diff, prod, div;
    printf("Enter two numbers: ");
    scanf("%f %f", &num1, &num2);
    sum  = num1 + num2;
    diff = num1 - num2;
    prod = num1 * num2;
    printf("\nResults:\n");
    printf("Sum: %.2f\n", sum);
    printf("Difference: %.2f\n", diff);
    printf("Product: %.2f\n", prod);
    if (num2 != 0) {
        div = num1 / num2;
        printf("Division: %.2f\n", div);
    } else {
        printf("Division: Error! Division by zero is not allowed.\n");
    }
     return 0;
}

2.	Write a C program to swap two numbers using a temporary variable.
#include <stdio.h>
int main() {
    int a, b, temp;
    printf("Enter first number: ");
    scanf("%d", &a);
    printf("Enter second number: ");
    scanf("%d", &b);
    printf("\nBefore swapping: a = %d, b = %d\n", a, b);
    temp = a;    // 1. Move 'a' into the temp container
    a = b;       // 2. Move 'b' into 'a' (now that 'a' is safe in temp)
    b = temp;    // 3. Move the value from temp into 'b'
    printf("After swapping:  a = %d, b = %d\n", a, b);
    return 0;
}

3.	Write a C program to swap two numbers without using a temporary variable.
#include <stdio.h>
int main() {
    int a, b;
    printf("Enter two integers: ");
    scanf("%d %d", &a, &b);
    printf("\nBefore swapping: a = %d, b = %d\n", a, b);
    a = a + b; // a now holds the sum of both
    b = a - b; // b becomes (original a + original b) - original b = original a
    a = a - b; // a becomes (original a + original b) - original a = original b
    printf("After swapping:  a = %d, b = %d\n", a, b);
    return 0;
}

4.	Write a C program to calculate the average of three numbers.
#include <stdio.h>
int main() {
    float num1, num2, num3, average;
    printf("Enter three numbers: ");
    scanf("%f %f %f", &num1, &num2, &num3);
    average = (num1 + num2 + num3) / 3;
    printf("The average of %.2f, %.2f, and %.2f is: %.2f\n", num1, num2, num3, average);
    return 0;
}

5.	Write a C program to convert kilometers into meters and centimeters.
#include <stdio.h>
int main() {
    float km, meters, cm;
    printf("Enter distance in kilometers: ");
    scanf("%f", &km);
    meters = km * 1000;
    cm = km * 100000;
    printf("\n%.2f Kilometers is equal to:\n", km);
    printf("%.2f Meters\n", meters);
    printf("%.2f Centimeters\n", cm);
    return 0;
}

